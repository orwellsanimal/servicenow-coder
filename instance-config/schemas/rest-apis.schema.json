{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ServiceNow Scripted REST APIs (sys_ws_definition)",
    "type": "object",
    "properties": {
        "rest_apis": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "sys_id": { "type": "string" },
                    "name": { "type": "string" },
                    "api_id": { "type": "string" },
                    "namespace": { "type": "string" },
                    "base_uri": { "type": "string" },
                    "active": { "type": "boolean" },
                    "scope": { "type": "string" },
                    "resources": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": { "type": "string" },
                                "http_method": { "type": "string" },
                                "relative_path": { "type": "string" }
                            }
                        }
                    }
                },
                "required": ["name", "api_id"]
            }
        }
    }
}
