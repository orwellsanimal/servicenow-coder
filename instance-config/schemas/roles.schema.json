{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ServiceNow Roles (sys_user_role)",
    "type": "object",
    "properties": {
        "roles": {
            "type": "object",
            "description": "Keyed by role name",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "sys_id": { "type": "string" },
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "elevated_privilege": { "type": "boolean" },
                    "scope": { "type": "string" }
                },
                "required": ["name"]
            }
        }
    }
}
