{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "CMDB Model Categories (cmdb_model_category)",
    "type": "object",
    "properties": {
        "model_categories": {
            "type": "object",
            "description": "Keyed by sys_id",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "name": { "type": "string" }
                },
                "required": ["name"]
            }
        }
    }
}
