#!/usr/bin/env sh
# Auto-sync CLAUDE.md and GEMINI.md before each commit.
# If either was modified, re-stage both files after the sync.

# Run the sync script (no-op if files already match)
node scripts/sync-docs.js || exit 1

# If either doc file is staged, re-stage both to ensure they match
if git diff --cached --name-only | grep -qE '^(CLAUDE|GEMINI)\.md$'; then
    git add CLAUDE.md GEMINI.md
fi
