{
    "name": "servicenow-coder",
    "version": "1.0.0",
    "private": true,
    "description": "ServiceNow Agent code development and SDLC workspace",
    "scripts": {
        "build": "pnpm --filter './apps/*' run build",
        "build:apps": "pnpm --filter './apps/*' run build",
        "build:examples": "pnpm --filter ./servicenow-sdk-examples run build",
        "check": "pnpm --filter scratch run check",
        "lint": "eslint",
        "format": "prettier --check \"**/*.{ts,js,json}\"",
        "pack:apps": "pnpm --filter './apps/*' run pack",
        "deploy": "node scripts/deploy.js",
        "ci": "pnpm run lint && pnpm run check && pnpm run build"
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=10"
    },
    "devDependencies": {
        "typescript": "~5.8.2",
        "prettier": "^3.8.1",
        "eslint": "^8.57.0"
    }
}
