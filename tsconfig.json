{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": "."
    },
    "exclude": [
        "node_modules",
        "dist",
        "servicenow-sdk",
        "servicenow-sdk-examples",
        "servicenow-docs"
    ]
}
